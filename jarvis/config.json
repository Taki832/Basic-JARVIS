{
  "ai": {
    "model": "qwen3:4b",
    "max_tokens": 1024,
    "temperature": 0.7,
    "context_turns": 20,
    "system_prompt": "You are JARVIS, a local AI assistant inspired by Iron Man's AI. Be concise (1-3 sentences unless detail is asked), helpful, and slightly witty. Never identify yourself as an LLM. You run locally and privately on the user's machine."
  },
  "voice": {
    "tts_enabled": false,
    "tts_rate": 175,
    "tts_volume": 0.9,
    "stt_enabled": false,
    "wake_word": "jarvis",
    "continuous_listening": false,
    "stt_timeout": 5,
    "stt_phrase_limit": 10
  },
  "safety": {
    "require_confirmation": true,
    "dangerous_rate_limit_seconds": 60,
    "protected_processes": [
      "explorer", "svchost", "system", "winlogon",
      "lsass", "csrss", "wininit", "services",
      "smss", "ntoskrnl", "dwm", "conhost"
    ]
  },
  "memory": {
    "long_term_file": "data/long_term_memory.json",
    "history_file": "data/conversation_history.json",
    "max_history_turns": 50
  },
  "logging": {
    "level": "INFO",
    "file": "logs/jarvis.log",
    "max_bytes": 5242880,
    "backup_count": 3
  },
  "plugins_dir": "plugins",
  "data_dir": "data",
  "logs_dir": "logs"
}
